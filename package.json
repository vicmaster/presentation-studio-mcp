{
  "name": "presentation-studio-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Local production-grade presentation generation, auditing, preview and extraction engine exposed via MCP",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./packages/* --filter=./apps/* run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint \"{apps,packages}/**/*.ts\"",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:mcp": "pnpm --filter @presentation-studio/mcp-server run dev",
    "cli": "tsx apps/cli/src/index.ts",
    "clean": "rimraf apps/*/dist packages/*/dist tmp/*"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
